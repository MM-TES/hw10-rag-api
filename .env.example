# =============================================================================
# HW10 — Production RAG API · environment template
# =============================================================================
# Copy this file to `.env` and fill in real values.
# Reference: ../_tasks/SETUP_CHECKLIST.md (full registration walkthrough).
# Never commit `.env` — it contains secrets and is .gitignore'd.
# =============================================================================

# --- OpenRouter (LLM gateway, 200+ models via single key) -------------------
# Get from: https://openrouter.ai/keys
# Top up $10 — this is the physical financial cap (402 returned past it).
OPENROUTER_API_KEY=sk-or-v1-...

# --- Anthropic (LLM-as-judge in Phase 2 + report interpretations) -----------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Qdrant Cloud (vector DB: chunks_collection + cache_collection) ---------
# Free tier 1GB. Get from: https://cloud.qdrant.io
QDRANT_URL=https://xxx.cloud.qdrant.io:6333
QDRANT_API_KEY=...
QDRANT_CHUNKS_COLLECTION=chunks_collection
QDRANT_CACHE_COLLECTION=cache_collection

# --- Upstash Redis (rate-limit token buckets, REST API only — no Lua) -------
# Free tier. Get from: https://console.upstash.com (REST API tab on DB page)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Supabase Postgres (cost tracking: request_logs table) ------------------
# Use connection pooler (port 6543) + asyncpg driver. Free tier.
# URL-encode special chars in password (e.g. `@` -> `%40`).
DATABASE_URL=postgresql+asyncpg://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Langfuse Cloud (tracing: full request pipeline spans) ------------------
# Free tier. Get from: https://cloud.langfuse.com → Project Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Fly.io (deployment, optional for Phase 1) ------------------------------
# Get from: `fly auth token` after `fly auth login`.
FLY_API_TOKEN=...

# =============================================================================
# Application tunables (defaults shown — override per environment if needed)
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_CONCURRENT_LLM_CALLS=20
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600
LLM_TIMEOUT_SECONDS=15
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CIRCUIT_BREAKER_OPEN_SECONDS=60
ENABLE_CACHE=true
ENABLE_FALLBACK=true
ENABLE_INJECTION_DEFENSE=true

# =============================================================================
# Phase 2 experiment safety controls — DO NOT loosen without explicit approval
# =============================================================================
# OpenRouter top-up is the hard ceiling ($10). HARD_STOP gives a 5% safety margin.
EXPERIMENT_BUDGET_USD=10.00
EXPERIMENT_HARD_STOP_USD=9.50
EXPERIMENT_PER_REQUEST_TIMEOUT_S=30
